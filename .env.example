# Chift CLI environment variables — copy to .env and fill in values

# API credentials (set via `chift auth setup` or provide here)
CHIFT_ACCOUNT_ID=
CHIFT_CLIENT_ID=
CHIFT_CLIENT_SECRET=

# Default consumer — avoids passing consumer_id on every command
CHIFT_CONSUMER_ID=

# API base URL (defaults to https://api.chift.eu)
# CHIFT_API_BASE_URL=https://api.chift.eu

# OpenAPI schema URL (derived from CHIFT_API_BASE_URL + /openapi.json if unset)
# CHIFT_OPENAPI_URL=

# Restrict allowed operation classes: read, write, dangerous, all (default: all)
# CHIFT_ALLOWED_OPERATIONS=read,write

# Show hidden endpoint groups
# CHIFT_SHOW_PLATFORM_ENDPOINTS=1   # exposes consumers, integrations
# CHIFT_SHOW_INTERNAL_ENDPOINTS=1   # exposes general, datastores, syncs, issues, m-c-p, webhooks
